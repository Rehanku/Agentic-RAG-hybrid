# ──────────────────────────────────────────────────────────────────────────────
# DeepRead — Environment Variable Reference
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Full URL of the deployed backend service (no trailing slash)
VITE_API_URL=https://deepread-backend-xxxx.run.app

# ── Backend ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=https://deepread-frontend-xxxx.run.app,http://localhost:5173

# HuggingFace embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cross-encoder reranker model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Google Gemini model version
GEMINI_MODEL=gemini-2.5-flash

# ── Cloud Run ─────────────────────────────────────────────────────────────────
# Port Cloud Run injects automatically; do not set manually in production
PORT=8080
