# ──────────────────────────────────────────────────────────────────────────────
# DeepRead — Environment Variable Reference
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Set this to your Render backend URL after first deploy.
# In Vercel: Project Settings → Environment Variables → VITE_API_URL
VITE_API_URL=https://deepread-backend.onrender.com

# ── Backend ───────────────────────────────────────────────────────────────────
# Your Google Gemini API key. Set this in the Render dashboard (never commit it).
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated list of allowed frontend origins for CORS.
# Update to your Vercel URL after frontend deploy.
ALLOWED_ORIGINS=https://deepread.vercel.app,http://localhost:5173

# Local model cache directory (baked into Docker image — do not change for prod)
HF_HOME=/app/models
TRANSFORMERS_CACHE=/app/models

# ── Model overrides (optional — defaults match Docker build ARGs) ─────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GEMINI_MODEL=gemini-2.5-flash

# ── Local dev only ────────────────────────────────────────────────────────────
PORT=10000
